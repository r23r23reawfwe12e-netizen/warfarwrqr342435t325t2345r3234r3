{
  "name": "selfquest-bot",
  "version": "1.0.0",
  "description": "SELFQUEST — Social RPG self-improvement Telegram bot",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "lint": "tsc --noEmit"
  },
  "keywords": ["telegram", "bot", "rpg", "self-improvement"],
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "dotenv": "^16.5.0",
    "i18next": "^25.2.1",
    "ioredis": "^5.6.1",
    "nanoid": "^5.1.5",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "prisma": "^6.9.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
